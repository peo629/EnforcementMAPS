# ──────────────────────────────────────────────────────────────────────────────
# EnforcementMAPS — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for local development.
# For EAS builds, these are configured per-profile in eas.json.
# ──────────────────────────────────────────────────────────────────────────────

# ─── API Server ──────────────────────────────────────────────────────────────
# Full URL to your deployed API server (includes protocol).
# Example: https://my-enforcement-api.up.railway.app
EXPO_PUBLIC_API_BASE_URL=

# API server domain only (without protocol). Used as fallback if
# EXPO_PUBLIC_API_BASE_URL is not set. The app will prepend https://.
# Example: my-enforcement-api.up.railway.app
EXPO_PUBLIC_DOMAIN=

# ─── Environment ─────────────────────────────────────────────────────────────
# Current environment name: development | preview | production
EXPO_PUBLIC_ENVIRONMENT=development

# Build environment flag (matches EXPO_PUBLIC_ENVIRONMENT)
APP_ENV=development

# ─── Expo / EAS ──────────────────────────────────────────────────────────────
# EAS project ID — already configured in app.config.ts for this project.
EAS_PROJECT_ID=c69eeb3a-1e1f-45c5-bb7e-c81917e47e86

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Android Google Maps API key (required for map rendering on Android)
# Already configured in eas.json build profiles.
GOOGLE_MAPS_API_KEY=AIzaSyCkhndYKPYh7EB7G0hLrQboZQEO9C7B9LQ

# ─── Backend / API Secrets ───────────────────────────────────────────────────
# JWT secret for API authentication (used by the backend server, NOT the app)
# Set this on your API server deployment (e.g., Railway environment variables)
JWT_SECRET=fcOYQAOQvLh3Op8Ribs49LYmGCIniTh7sORDnOaHW6o=

# ─── Optional Overrides ─────────────────────────────────────────────────────
# These have sensible defaults and typically don't need to be changed.
# APP_FAMILY=CIVIC_MAPS
# APP_PRODUCT=ENFORCEMENT_MAPS
# EXPO_APP_NAME=EnforcementMAPS
# EXPO_APP_SLUG=enforcement-maps
